{
	"compilerOptions": {
		"declaration": true,
		"outDir": "./dist",
		"lib": ["ES2022"],
		"removeComments": true,
		"target": "es2020",
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"forceConsistentCasingInFileNames": true,
		"esModuleInterop": true,
		"moduleResolution": "node",
		"verbatimModuleSyntax": true
	}
}